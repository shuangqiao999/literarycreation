# StrategyForge 环境变量配置
# 复制此文件为 .env 或直接设置环境变量

# ── LLM ──
FORGE_LLM_BASE=http://127.0.0.1:1234/v1
FORGE_LLM_KEY=lm-studio
FORGE_LLM_MODEL=qwen/qwen3.5-9b

# ── Embedding ──
FORGE_EMBED_BASE=http://127.0.0.1:1234/v1
FORGE_EMBED_KEY=lm-studio
FORGE_EMBED_MODEL=text-embedding-embeddinggemma-300m-qat

# ── Deduction ──
FORGE_MAX_AGENTS=200
FORGE_DEFAULT_ROUNDS=10
FORGE_CANDIDATE_COUNT=3
FORGE_LLM_TEMPERATURE=0.3
FORGE_MAX_CONCURRENT=2

# ── Data ──
FORGE_DATA_DIR=./data
FORGE_PROJECT_ROOT=.
